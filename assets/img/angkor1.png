,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/57/57ed49eab235d44ee96fe9efac8210d854781f37.jpg\",\"width\":719,\"height\":922},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/c8/c8007becc8162a1c76cc587430348c013a07d94e.jpg\",\"width\":960,\"height\":720},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/6b/6b3b615c7c49b0a40a76c99e4f245edbfe2c6d38.jpg\",\"width\":960,\"height\":480},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/05/052f5afb1069605267dfa770e17133c5f0b8484c.jpg\",\"width\":776,\"height\":500},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/57/570ee7c34c63647ce676f4d05490be6cedd83884.jpg\",\"width\":960,\"height\":480},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/41/41ec87cfabfcbf88dc98a7e7734cc5e84cc3d314.jpg\",\"width\":1280,\"height\":854},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}}],\"version\":\"2.19.1\"}","isPR":false,"format":"EDITOR_JS","category":{"__typename":"ArticleCategory","slug":"teenager","name":{"__typename":"NameFormat","local":"យុវវ័យ"}},"categorySub":{"__typename":"ArticleCategory","slug":"teenager-entertainment","name":{"__typename":"NameFormat","local":"កម្សាន្ត"}},"tags":[],"celebrities":[],"author":{"__ref":"ArticleAuthor:337"},"publishedDateTime":{"__typename":"DateTimeFormat","displayDate":{"__typename":"NameFormat","local":"០៧-កក្កដា-២០២១"},"displayTime":{"__typename":"NameFormat","local":"១២ល្ងាច"}},"elapsedTime":{"__typename":"NameFormat","local":"៥ ឆ្នាំមុន"},"suggestion":{"__typename":"ArticleSuggestion","nextId":157869,"articlesRelated":[{"__ref":"ArticleRelated:203747"},{"__ref":"ArticleRelated:196551"},{"__ref":"ArticleRelated:196550"},{"__ref":"ArticleRelated:196523"}]}}},"key":157883,"data":{"article":{"__typename":"Article","id":157883,"siteId":0,"title":"សម្រស់ដ៏ស្អាត និងទេសភាពដ៏ទាក់ទាញរបស់ ប្រាសាទអង្គរវត្ត តែងដក់ជាប់ ក្នុងបេះដូងខ្មែរមិនអាចបំភ្លេចបាន!","summary":"តោះមកទស្សនារូបភាព ជាមួយសម្រស់ដ៏ស្រស់ស្អាត ដែលបង្ហាញពីភាពទាក់ទាញរកជាតិសាសន៍ឯណាមកប្រៀបផ្ទឹមពុំបានឡើយ របស់ប្រាសាទអង្គរវត្ត តែងដក់ជាប់បេះដូងជនរួមជាតិខ្មែរមិនអាចបំភ្លេចបាន!","audio":"","thumbnail":"//s9.kh1.co/dd/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg","thumbnailPremium":"//s9.kh1.co/dd/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg","content":"{\"time\":1625643185282,\"blocks\":[{\"type\":\"paragraph\",\"data\":{\"text\":\"\u003cb\u003eកម្សាន្ត ៖\u003c/b\u003e ដូនតាខ្មែរយើងបានបន្សល់ទុកនូវសម្បត្តិវប្បធម៌\\nអក្សរ ភាសា ទំនៀមទម្លាប់ប្រពៃណីជាច្រើនរាប់មិនអស់ ជាពិសេសសំណង់ស្ថាបត្យកម្មដ៏មហស្ចារ្យរបស់ខ្មែរដែលផុសឡើង នៅលើទឹកដីនៃខេត្តសៀមរាប\\nគឺប្រសាទអង្គរវត្តនេះឯង។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ជាមួយគ្នានេះដែរ បើនិយាយដល់ប្រាសាទអង្គរវត្ត\\nឬយើងហៅថាអង្គរតូច ពេលណាគឺប្រជាជនខ្មែរគ្រប់រូបតែងតែស្ងប់ស្ងែងក្នុងចិត្ត\\nមានមោទនភាពយ៉ាងខ្លាំង ចំពោះសំណង់ស្ថាបត្យកម្មដ៏មហាអស្ចារ្យរបស់ដូនតាខ្មែរ\\nដែលបង្ហាញឡើងនូវកេរមរតក វប្បធម៌ដ៏ថ្កើងថ្កាន ជាមួយអាយុកាលដ៏យូរលង់ណាស់មកហើយ និងនៅតែរក្សារូបរាងទាក់ទាញ​​ប្រៀបដូចជាទេពនិម្មិតយ៉ាងដូច្នោះដែរ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ទន្ទឹមនឹងសោភណ្ឌភាព\\nក៏ដូចជាទេសភាពដ៏ស្រស់ត្រកាលរបស់ប្រាសាទអង្គរវត្ត យើងពិតជាទទួលស្គាល់មិនអាចប្រកែកបានថា សម្រស់របស់ប្រាសាទនេះគឺទាក់ទាញខ្លាំងយ៉ាងណា ទោះបីយើងមើលពីជ្រុងខាងណា ក៏នៅតែឃើញស្អាត ដែលលេចចេញនូវសម្រស់ដ៏ហាអស្ចារ្យពិតៗ អាចនិយាយបានថា គឺមានតែមួយលើលោក ល្អហួសរកអ្វីមកប្រៀបផ្ទឹមពុំបានឡើយ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ក្រៅពីភាពទាក់ទាញជាមួយភាពលេចធ្លោរបស់សំណង់ប្រាសាទនេះហើយ\\nទីនោះក៏ជាកន្លែងដែលពោរពេញទៅដោយបរិយាកាសបរិសុទ្ធ វាលស្មៅពណ៌បៃតងខ្ចីធំល្វឹងល្វើយ ដើមឈើធំៗដែលផ្ដល់នូម្លប់ត្រជាក់ត្រឈឹងត្រឈៃនៅព័ន្ធជុំវិញ មានស្រះទឹកថ្លាយង់ ព្រមជាមួយសម្លេងសត្វយំបង្កើតជាតន្ត្រីកំដរអារម្មណ៍ទៀត\\nរឹតតែធ្វើឲ្យអ្នកទេសចរមិនចង់ឈានជើងចេញពីអង្គរវត្តឡើយ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"យ៉ាងណាមិញ មិនថានាពេលរដូវវស្សា រដូវប្រាំង\\nពេលធ្លាក់ ក្រោយភ្លៀងធ្លាក់ ពេលថ្ងៃលិច ថ្ងៃរះ សោភណ្ឌភាពរបស់ប្រាង្គប្រាសាទនេះ មើលទៅក៏នៅតែស្អាត ល្អ ក្នុងកែវភ្នែកអ្នកទស្សនាគ្រប់ពេលវេលា មើលយ៉ាងណាក៏នៅតែល្អឥតខ្ចោះដដែល៕\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"\u003cb\u003eសូមទស្សនារូបភាពខាងក្រោម ៖\u003c/b\u003e\"}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/ee/ee1ea13d1f8746db6fbedd460bc1dab0a6d218ad.jpg\",\"width\":750,\"height\":499},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/58/5896751822a83ecec1ea7aa6f826c2588ee14a63.jpg\",\"width\":593,\"height\":395},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/1d/1d7a18b7770690f9c9bacad1c1b6eb792b164189.jpg\",\"width\":960,\"height\":640},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/76/76138b2da53220bb92623d9be261f6843d236d43.jpg\",\"width\":1280,\"height\":853},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/64/643bcea473569df9729f7715e564472774cf235e.jpg\",\"width\":960,\"height\":641},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/c0/c063