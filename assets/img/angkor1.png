; left: 0px; top: 0px; visibility: hidden;"><img src="./angkor1_files/lg.php" width="0" height="0" alt="" style="width: 0px; height: 0px;"></div></ins></div><div class="revive-ads mobile full-width" style="padding-bottom:83.33333333333334%;min-height:250px;min-width:300px"></div><div class="article-grid"><article class="grid-article-detail"><h1 class="grid-article-title">សម្រស់ដ៏ស្អាត និងទេសភាពដ៏ទាក់ទាញរបស់ ប្រាសាទអង្គរវត្ត តែងដក់ជាប់ ក្នុងបេះដូងខ្មែរមិនអាចបំភ្លេចបាន!</h1><div class="grid-article-thumbnail"><img alt="//s9.kh1.co/dd/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg" loading="lazy" width="800" height="420" decoding="async" data-nimg="1" style="color: transparent;" src="./angkor1_files/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg"></div><div class="grid-article-summary"><div class="article-share"><i class="fal fa-share-nodes fa-xl"></i><div class="article-share-fallback "><div class="article-share-btn"><i class="fab fa-facebook fa-2x fa-fw" style="color:#4267B2"></i></div><div class="article-share-btn"><i class="fab fa-facebook-messenger fa-2x fa-fw" style="color:#006AFF"></i></div><div class="article-share-btn"><i class="fab fa-telegram fa-2x fa-fw" style="color:#0088CC"></i></div><div class="article-share-btn"><i class="fab fa-twitter fa-2x fa-fw" style="color:#00ACEE"></i></div><div class="article-share-btn"><i class="fab fa-whatsapp fa-2x fa-fw" style="color:#4FCE5D"></i></div><div class="article-share-btn"><i class="fab fa-viber fa-2x fa-fw" style="color:#665CAC"></i></div><div class="article-share-btn"><i class="fab fa-linkedin fa-2x fa-fw" style="color:#0E76A8"></i></div></div></div><div class="article-summary-category">យុវវ័យ</div><br><span class="article-summary-datetime"><i class="fal fa-calendar-days"></i>&nbsp;<!-- -->០៧-កក្កដា-២០២១</span><span class="article-summary-datetime"><i class="fal fa-clock"></i>&nbsp;<!-- -->១២ល្ងាច<!-- -->&nbsp;·&nbsp;<!-- -->៥ ឆ្នាំមុន</span><p class="article-summary-title-sub">តោះមកទស្សនារូបភាព ជាមួយសម្រស់ដ៏ស្រស់ស្អាត ដែលបង្ហាញពីភាពទាក់ទាញរកជាតិសាសន៍ឯណាមកប្រៀបផ្ទឹមពុំបានឡើយ របស់ប្រាសាទអង្គរវត្ត តែងដក់ជាប់បេះដូងជនរួមជាតិខ្មែរមិនអាចបំភ្លេចបាន!</p></div><div class="grid-article-content"><div id="gax-inpage-async-1700711764"><script src="./angkor1_files/ad-exchange.js.download" type="text/javascript"></script><script type="text/javascript" src="./angkor1_files/saved_resource"></script></div><div class="article-ads"><div class="revive-ads mobile origin" style="padding-bottom:NaN%;min-height:0px;min-width:0px"></div></div><p><b>កម្សាន្ត ៖</b> ដូនតាខ្មែរយើងបានបន្សល់ទុកនូវសម្បត្តិវប្បធម៌
អក្សរ ភាសា ទំនៀមទម្លាប់ប្រពៃណីជាច្រើនរាប់មិនអស់ ជាពិសេសសំណង់ស្ថាបត្យកម្មដ៏មហស្ចារ្យរបស់ខ្មែរដែលផុសឡើង នៅលើទឹកដីនៃខេត្តសៀមរាប
គឺប្រសាទអង្គរវត្តនេះឯង។</p><a class="article-content-telegram-link" target="_blank" rel="noreferrer" href="https://t.me/khmerload"><i class="fab fa-telegram fa-beat"></i> <!-- -->ចូលរួមជាមួយពួកយើងក្នុង Telegram ដើម្បីទទួលបានព័ត៌មានរហ័ស</a><p>ជាមួយគ្នានេះដែរ បើនិយាយដល់ប្រាសាទអង្គរវត្ត
ឬយើងហៅថាអង្គរតូច ពេលណាគឺប្រជាជនខ្មែរគ្រប់រូបតែងតែស្ងប់ស្ងែងក្នុងចិត្ត
មានមោទនភាពយ៉ាងខ្លាំង ចំពោះសំណង់ស្ថាបត្យកម្មដ៏មហាអស្ចារ្យរបស់ដូនតាខ្មែរ
ដែលបង្ហាញឡើងនូវកេរមរតក វប្បធម៌ដ៏ថ្កើងថ្កាន ជាមួយអាយុកាលដ៏យូរលង់ណាស់មកហើយ និងនៅតែរក្សារូបរាងទាក់ទាញ​​ប្រៀបដូចជាទេពនិម្មិតយ៉ាងដូច្នោះដែរ។</p><div class="d-none d-block-mobile" style="text-align:center"><div id="gax-inpage-async-1700711916"><script src="./angkor1_files/ad-exchange.js.download" type="text/javascript"></script><script type="text/javascript" src="./angkor1_files/saved_resource(1)"></script><script></script></div><div id="gax-inpage-async-1749105450"><script src="./angkor1_files/ad-exchange.js.download" type="text/javascript"></script><script type="text/javascript" src="./angkor1_files/saved_resource(2)"></script><script></script></div></div><p>ទន្ទឹមនឹងសោភណ្ឌភាព
ក៏ដូចជាទេសភាពដ៏ស្រស់ត្រកាលរបស់ប្រាសាទអង្គរវត្ត យើងពិតជាទទួលស្គាល់មិនអាចប្រកែកបានថា សម្រស់របស់ប្រាសាទនេះគឺទាក់ទាញខ្លាំងយ៉ាងណា ទោះបីយើងមើលពីជ្រុងខាងណា ក៏នៅតែឃើញស្អាត ដែលលេចចេញនូវសម្រស់ដ៏ហាអស្ចារ្យពិតៗ អាចនិយាយបានថា គឺមានតែមួយលើលោក ល្អហួសរកអ្វីមកប្រៀបផ្ទឹមពុំបានឡើយ។</p><p>ក្រៅពីភាពទាក់ទាញជាមួយភាពលេចធ្លោរបស់សំណង់ប្រាសាទនេះហើយ
ទីនោះក៏ជាកន្លែងដែលពោរពេញទៅដោយបរិយាកាសបរិសុទ្ធ វាលស្មៅពណ៌បៃតងខ្ចីធំល្វឹងល្វើយ ដើមឈើធំៗដែលផ្ដល់នូម្លប់ត្រជាក់ត្រឈឹងត្រឈៃនៅព័ន្ធជុំវិញ មានស្រះទឹកថ្លាយង់ ព្រមជាមួយសម្លេងសត្វយំបង្កើតជាតន្ត្រីកំដរអារម្មណ៍ទៀត
រឹតតែធ្វើឲ្យអ្នកទេសចរមិនចង់ឈានជើងចេញពីអង្គរវត្តឡើយ។</p><div class="article-ads"><div class="revive-ads tablet full-width" style="padding-bottom:21.818181818181817%;min-height:240px;min-width:1100px"></div><div class="revive-ads mobile underlay origin" style="padding-bottom:150%;min-height:450px;min-width:300px"></div></div><p>យ៉ាងណាមិញ មិនថានាពេលរដូវវស្សា រដូវប្រាំង
ពេលធ្លាក់ ក្រោយភ្លៀងធ្លាក់ ពេលថ្ងៃលិច ថ្ងៃរះ សោភណ្ឌភាពរបស់ប្រាង្គប្រាសាទនេះ មើលទៅក៏នៅតែស្អាត ល្អ ក្នុងកែវភ្នែកអ្នកទស្សនាគ្រប់ពេលវេលា មើលយ៉ាងណាក៏នៅតែល្អឥតខ្ចោះដដែល៕</p><p><b>សូមទស្សនារូបភាពខាងក្រោម ៖</b></p><div class="article-content-image-modal"><figure class="article-content-image"><img alt="ទេសភាពនៅ ប្រាសាទអង្គរវត្ត" loading="lazy" width="750" height="499" decoding="async" data-nimg="1" style="color: transparent;" src="./angkor1_files/ee1ea13d1f8746db6fbedd460bc1dab0a6d218ad.jpg"><figcaption class="article-content-caption"><i class="fal fa-image"></i> <span>ទេសភាពនៅ ប្រាសាទអង្គរវត្ត</span></figcaption></figure></div><div class="article-content-image-modal"><figure class="article-content-image"><img alt="ទេសភាពនៅ ប្រាសាទអង្គរវត្ត" loading="lazy" width="593" height="395" decoding="async" data-nimg="1" style="color: transparent;" src="./angkor1_files/5896751822a83ecec1ea7aa6f826c2588ee14a63.jpg"><figcaption class="article-content-caption"><i class="fal fa-image"></i> <span>ទេសភាពនៅ ប្រាសាទអង្គរវត្ត</span></figcaption></figure></div><div class="article-ads"><div class="revive-ads tablet full-width" style="padding-bottom:21.818181818181817%;min-height:240px;min-width:1100px"></div><div class="revive-ads mobile underlay origin" style="padding-bottom:150%;min-height:450px;min-width:300px"></div></div><div class="article-content-image-modal"><figure class="article-content-image"><img alt="ទេសភាពនៅ ប្រាសាទអង្គរវត្ត" loading="lazy" width="960" height="640" decoding="async" data-nimg="1" style="color: transparent;" src="./angkor1_files/1d7a18b7770690f9c9bacad1c1b6eb792b164189.jpg"><figcaption class="article-content-caption"><i class="fal fa-image"></i> <span>ទេសភាពនៅ ប្រាសាទអង្គរវត្ត</span></figcaption></figure></div><div class="article-content-image-modal"><figure class="article-content-image"><img alt="ទេសភាពនៅ ប្រាសាទអង្គរវត្ត" loading="lazy" width="1280" height="853" decoding="async" data-nimg="1" style="color: transparent;" src="./angkor1_files/76138b2da53220bb92623d9b