fa-house fa-fw"></i></div></a><a class="navbar-bottom-items " href="https://www.khmerload.com/audio"><div class="navbar-bottom-item-wrapper"><i class="fal fa-headphones fa-fw"></i></div></a><a class="navbar-bottom-items " href="https://www.khmerload.com/menu"><div class="navbar-bottom-item-wrapper"><i class="fal fa-bars fa-fw"></i></div></a></div></div></div><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"initialApolloState":{"ROOT_QUERY":{"__typename":"Query","adsTakeOver":{"__typename":"AdsTakeOver","pageFront":false,"pageArticle":false},"article({\"id\":157883,\"siteId\":1})":{"__ref":"Article:157883"}},"ArticleAuthor:337":{"__typename":"ArticleAuthor","id":337,"groupId":2,"name":{"__typename":"NameFormat","en":"Keo Rong"},"nameDisplay":"K.R","avatar":"https://www.gravatar.com/avatar/12f918ba1c269fe13005b383463a5a85?s=100\u0026d=robohash\u0026r=g"},"ArticleRelated:203747":{"__typename":"ArticleRelated","id":203747,"title":"បើមានសញ្ញា ៧យ៉ាងនេះ បានន័យថាគាត់គិតចង់រៀបការជាមួយអ្នកហើយ","thumbnailPremium":"//s9.kh1.co/0c/0c3b0a74303ebad80d922af7155cfa3dad1c3b6e.jpg","audio":"","publishedDateTime":{"__typename":"DateTimeFormat","displayDate":{"__typename":"NameFormat","local":"២៤-ឧសភា-២០២៤"},"displayTime":{"__typename":"NameFormat","local":"៤ល្ងាច"}},"elapsedTime":{"__typename":"NameFormat","local":"២ ឆ្នាំមុន"}},"ArticleRelated:196551":{"__typename":"ArticleRelated","id":196551,"title":"ហៅតារានិករទាំងនេះ Date ដូចហៅគោមើលកុន","thumbnailPremium":"//s9.kh1.co/8f/8f08e1fec693bfe0e4efe043e56bc85b8597a469.jpeg","audio":"","publishedDateTime":{"__typename":"DateTimeFormat","displayDate":{"__typename":"NameFormat","local":"២៤-មីនា-២០២៣"},"displayTime":{"__typename":"NameFormat","local":"២ល្ងាច"}},"elapsedTime":{"__typename":"NameFormat","local":"៣ ឆ្នាំមុន"}},"ArticleRelated:196550":{"__typename":"ArticleRelated","id":196550,"title":"តារានិករទាំងនេះ ស្អប់បំផុត ការធ្លាក់ក្នុងអន្លង់ស្នេហ៍","thumbnailPremium":"//s9.kh1.co/ee/ee2e7c73615abb0637d0dd2cf7502b04301edc0d.jpeg","audio":"","publishedDateTime":{"__typename":"DateTimeFormat","displayDate":{"__typename":"NameFormat","local":"២៤-មីនា-២០២៣"},"displayTime":{"__typename":"NameFormat","local":"២ល្ងាច"}},"elapsedTime":{"__typename":"NameFormat","local":"៣ ឆ្នាំមុន"}},"ArticleRelated:196523":{"__typename":"ArticleRelated","id":196523,"title":"កំពូលតារានិករ អត់ធ្មត់បំផុត ក្នុងទំនាក់ទំនង","thumbnailPremium":"//s9.kh1.co/cc/cc96c93aa65c2b13d384ee82f3e61585928a6fb0.jpeg","audio":"","publishedDateTime":{"__typename":"DateTimeFormat","displayDate":{"__typename":"NameFormat","local":"២៣-មីនា-២០២៣"},"displayTime":{"__typename":"NameFormat","local":"៣ល្ងាច"}},"elapsedTime":{"__typename":"NameFormat","local":"៣ ឆ្នាំមុន"}},"Article:157883":{"__typename":"Article","id":157883,"siteId":0,"title":"សម្រស់ដ៏ស្អាត និងទេសភាពដ៏ទាក់ទាញរបស់ ប្រាសាទអង្គរវត្ត តែងដក់ជាប់ ក្នុងបេះដូងខ្មែរមិនអាចបំភ្លេចបាន!","summary":"តោះមកទស្សនារូបភាព ជាមួយសម្រស់ដ៏ស្រស់ស្អាត ដែលបង្ហាញពីភាពទាក់ទាញរកជាតិសាសន៍ឯណាមកប្រៀបផ្ទឹមពុំបានឡើយ របស់ប្រាសាទអង្គរវត្ត តែងដក់ជាប់បេះដូងជនរួមជាតិខ្មែរមិនអាចបំភ្លេចបាន!","audio":"","thumbnail":"//s9.kh1.co/dd/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg","thumbnailPremium":"//s9.kh1.co/dd/ddc69fa74555237ca4b183d594f34e90416ad3dc.jpg","content":"{\"time\":1625643185282,\"blocks\":[{\"type\":\"paragraph\",\"data\":{\"text\":\"\u003cb\u003eកម្សាន្ត ៖\u003c/b\u003e ដូនតាខ្មែរយើងបានបន្សល់ទុកនូវសម្បត្តិវប្បធម៌\\nអក្សរ ភាសា ទំនៀមទម្លាប់ប្រពៃណីជាច្រើនរាប់មិនអស់ ជាពិសេសសំណង់ស្ថាបត្យកម្មដ៏មហស្ចារ្យរបស់ខ្មែរដែលផុសឡើង នៅលើទឹកដីនៃខេត្តសៀមរាប\\nគឺប្រសាទអង្គរវត្តនេះឯង។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ជាមួយគ្នានេះដែរ បើនិយាយដល់ប្រាសាទអង្គរវត្ត\\nឬយើងហៅថាអង្គរតូច ពេលណាគឺប្រជាជនខ្មែរគ្រប់រូបតែងតែស្ងប់ស្ងែងក្នុងចិត្ត\\nមានមោទនភាពយ៉ាងខ្លាំង ចំពោះសំណង់ស្ថាបត្យកម្មដ៏មហាអស្ចារ្យរបស់ដូនតាខ្មែរ\\nដែលបង្ហាញឡើងនូវកេរមរតក វប្បធម៌ដ៏ថ្កើងថ្កាន ជាមួយអាយុកាលដ៏យូរលង់ណាស់មកហើយ និងនៅតែរក្សារូបរាងទាក់ទាញ​​ប្រៀបដូចជាទេពនិម្មិតយ៉ាងដូច្នោះដែរ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ទន្ទឹមនឹងសោភណ្ឌភាព\\nក៏ដូចជាទេសភាពដ៏ស្រស់ត្រកាលរបស់ប្រាសាទអង្គរវត្ត យើងពិតជាទទួលស្គាល់មិនអាចប្រកែកបានថា សម្រស់របស់ប្រាសាទនេះគឺទាក់ទាញខ្លាំងយ៉ាងណា ទោះបីយើងមើលពីជ្រុងខាងណា ក៏នៅតែឃើញស្អាត ដែលលេចចេញនូវសម្រស់ដ៏ហាអស្ចារ្យពិតៗ អាចនិយាយបានថា គឺមានតែមួយលើលោក ល្អហួសរកអ្វីមកប្រៀបផ្ទឹមពុំបានឡើយ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"ក្រៅពីភាពទាក់ទាញជាមួយភាពលេចធ្លោរបស់សំណង់ប្រាសាទនេះហើយ\\nទីនោះក៏ជាកន្លែងដែលពោរពេញទៅដោយបរិយាកាសបរិសុទ្ធ វាលស្មៅពណ៌បៃតងខ្ចីធំល្វឹងល្វើយ ដើមឈើធំៗដែលផ្ដល់នូម្លប់ត្រជាក់ត្រឈឹងត្រឈៃនៅព័ន្ធជុំវិញ មានស្រះទឹកថ្លាយង់ ព្រមជាមួយសម្លេងសត្វយំបង្កើតជាតន្ត្រីកំដរអារម្មណ៍ទៀត\\nរឹតតែធ្វើឲ្យអ្នកទេសចរមិនចង់ឈានជើងចេញពីអង្គរវត្តឡើយ។\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"យ៉ាងណាមិញ មិនថានាពេលរដូវវស្សា រដូវប្រាំង\\nពេលធ្លាក់ ក្រោយភ្លៀងធ្លាក់ ពេលថ្ងៃលិច ថ្ងៃរះ សោភណ្ឌភាពរបស់ប្រាង្គប្រាសាទនេះ មើលទៅក៏នៅតែស្អាត ល្អ ក្នុងកែវភ្នែកអ្នកទស្សនាគ្រប់ពេលវេលា មើលយ៉ាងណាក៏នៅតែល្អឥតខ្ចោះដដែល៕\"}},{\"type\":\"paragraph\",\"data\":{\"text\":\"\u003cb\u003eសូមទស្សនារូបភាពខាងក្រោម ៖\u003c/b\u003e\"}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/ee/ee1ea13d1f8746db6fbedd460bc1dab0a6d218ad.jpg\",\"width\":750,\"height\":499},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/58/5896751822a83ecec1ea7aa6f826c2588ee14a63.jpg\",\"width\":593,\"height\":395},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/1d/1d7a18b7770690f9c9bacad1c1b6eb792b164189.jpg\",\"width\":960,\"height\":640},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\":false}},{\"type\":\"image\",\"data\":{\"file\":{\"url\":\"//s9.kh1.co/76/76138b2da53220bb92623d9be261f6843d236d43.jpg\",\"width\":1280,\"height\":853},\"caption\":\"ទេសភាពនៅ ប្រាសាទអង្គរវត្ត\",\"withBorder\":false,\"stretched\":false,\"withBackground\"